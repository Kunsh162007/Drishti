# ============================================================================
# DRISHTI — production environment (TEMPLATE)
# ----------------------------------------------------------------------------
# Copy to `.env.production` and fill every CHANGE_ME. In a sovereign / GovCloud
# deployment these secrets are injected from an HSM/KMS at runtime, NOT stored
# on disk. This file documents every variable the production app consumes.
#
#   cp .env.production.example .env.production
#   docker compose --env-file .env.production up -d
# ============================================================================

ENV=production

# ---- 1) PostgreSQL + PostGIS (relational + spatial store) ------------------
# Compose builds the DB container from these three:
POSTGRES_USER=drishti
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=drishti
# The app reads DATABASE_URL. Point it at the compose db service, or a managed
# cloud Postgres. Must be the psycopg driver URL:
DATABASE_URL=postgresql+psycopg://drishti:CHANGE_ME_strong_db_password@db:5432/drishti

# ---- 2) JWT auth secret  (REQUIRED) ----------------------------------------
# Generate:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_generate_a_48_byte_random_secret
JWT_EXPIRE_MIN=60

# ---- 3) Field-encryption master key  (REQUIRED) ----------------------------
# 32-byte url-safe base64 Fernet key. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_ENCRYPTION_KEY=CHANGE_ME_fernet_key

# ---- 4) Default admin (seeded on first boot only) --------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password
ADMIN_FULL_NAME=DRISHTI Administrator

# ---- 5) Assistant LLM ------------------------------------------------------
# none = free grounded/extractive (no key). For real generative answers pick one:
#   anthropic (Claude)  | groq (free-tier Llama) | openai
LLM_PROVIDER=none
LLM_API_KEY=
LLM_MODEL=
# Examples:
#   LLM_PROVIDER=anthropic ; LLM_MODEL=claude-opus-4-8 ; LLM_API_KEY=sk-ant-...
#   LLM_PROVIDER=groq      ; LLM_MODEL=llama-3.3-70b-versatile ; LLM_API_KEY=gsk_...

# ---- 6) Neo4j graph DB (optional — networks/communities) -------------------
# If unset/unreachable the app falls back to SQL graph queries automatically.
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_neo4j_password

# ---- 7) Qdrant vector store (optional — semantic RAG) ----------------------
# If unset/unreachable the assistant falls back to keyword retrieval.
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=drishti_firs
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- 8) Hardening ----------------------------------------------------------
RATE_LIMIT_PER_MIN=120
# Comma-separated allowed browser origins (your SPA / SSO domain):
CORS_ORIGINS=https://drishti.example.gov.in
DOMAIN=drishti.example.gov.in
