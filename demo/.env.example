# ---- DRISHTI demo configuration (copy to .env) ----
# Demo defaults are 100% free. To go to production, change the values below.

DRISHTI_MODE=demo

# SQLite (free, bundled). For production use Postgres/PostGIS:
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/drishti
# DATABASE_URL=sqlite:///./demo/data/drishti_demo.db

# Assistant model. 'none' = free, deterministic, grounded extractive answers (no key needed).
# Production options: anthropic (Claude), groq (free-tier Llama), openai.
LLM_PROVIDER=none
LLM_API_KEY=
# LLM_MODEL=claude-opus-4-8        # for anthropic
# LLM_MODEL=llama-3.3-70b-versatile  # for groq (has a free tier)

PORT=8000
